{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": [
        "NODE_ENV",
        "VERCEL_ENV",
        "NEXT_PUBLIC_*",
        "SUPABASE_*",
        "DATABASE_URL",
        "OPENAI_API_KEY",
        "DEEPSEEK_API_KEY",
        "PERPLEXITY_API_KEY",
        "GEMINI_API_KEY",
        "GOOGLE_API_KEY",
        "ANTHROPIC_API_KEY",
        "WORDPRESS_ENCRYPTION_KEY",
        "PAYMENT_GATEWAY_API_KEY",
        "PAYMENT_GATEWAY_SITE_CODE",
        "PAYMENT_GATEWAY_ENV",
        "PAYMENT_GATEWAY_WEBHOOK_SECRET",
        "CRON_SECRET",
        "CF_AI_GATEWAY_*",
        "CF_BROWSER_RENDERING_*",
        "CF_EMAIL_*",
        "TURNSTILE_*",
        "SHOPLINE_*",
        "OAUTH_STATE_SECRET",
        "GOOGLE_OAUTH_*",
        "VERCEL_OIDC_TOKEN"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "lint": {}
  }
}
