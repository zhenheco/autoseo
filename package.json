{
  "name": "seo-monorepo",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "lint:staged": "pnpm --filter @seo/web exec lint-staged",
    "clean": "turbo clean && rm -rf node_modules"
  },
  "devDependencies": {
    "tsx": "^4.20.6",
    "turbo": "^2.0.0",
    "typescript": "^5.5.0"
  },
  "pnpm": {
    "overrides": {
      "axios@>=1.0.0 <1.18.1": "1.18.1",
      "fast-xml-parser@>=5.0.0 <5.7.0": "5.7.0",
      "follow-redirects@<=1.15.11": "1.16.0",
      "form-data@>=4.0.0 <4.0.6": "4.0.6",
      "minimatch@<3.1.4": ">=3.1.4",
      "protobufjs@<=7.6.2": "7.6.4",
      "@types/react": "19.2.2",
      "@types/react-dom": "19.2.2",
      "csstype": "3.2.3"
    }
  }
}
