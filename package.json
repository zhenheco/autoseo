{
  "name": "seo-monorepo",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "lint:staged": "pnpm --filter @seo/web exec lint-staged",
    "clean": "turbo clean && rm -rf node_modules"
  },
  "devDependencies": {
    "tsx": "^4.20.6",
    "turbo": "^2.0.0",
    "typescript": "^5.5.0"
  },
  "pnpm": {
    "overrides": {
      "axios@>=1.0.0 <1.13.5": ">=1.13.5",
      "fast-xml-parser@>=5.0.0 <5.3.6": ">=5.3.6",
      "minimatch@<3.1.4": ">=3.1.4",
      "@types/react": "19.2.2",
      "@types/react-dom": "19.2.2",
      "csstype": "3.2.3"
    }
  }
}
